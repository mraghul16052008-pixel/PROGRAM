#include <stdio.h>
int main() {
    int r,c;
    scanf("%d %d",&r,&c);
    int mat[r][c];
    for(int i=0;i<r;i++){
        for(int j=0;j<c;j++){
            scanf("%d",&mat[i][j]);
        }
    }
    for(int i=0;i<r;i++){
        for(int j=0;j<c;j++){
            int sum=0;
            for(int x=i-1;x<=i+1;x++){
                for(int y=j-1;y<=j+1;y++){
                    if(x>=0 && x<r && y>=0 && y<c &&(x!=i || y!=j)){
                        sum+=mat[x][y];
                    }
                }
            }
            printf("%d ",sum);
        }
        printf("\n");
    }
    return 0;
}
